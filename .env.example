# ─── OrcheFlowAI Environment Variables ────────────────────────────
# Copy this file to .env and fill in values before running locally

# ── Vertex AI (No API key needed — uses ADC / Service Account) ────
GOOGLE_CLOUD_PROJECT=genai-apac-2026-491004
GOOGLE_CLOUD_LOCATION=us-central1

# Model Garden model IDs (Vertex AI Model Garden)
GEMINI_ORCHESTRATOR_MODEL=gemini-2.5-flash
GEMINI_SUBAGENT_MODEL=gemini-2.0-flash

# ── Database (AlloyDB or Cloud SQL Postgres) ───────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/orcheflow
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── API Security ───────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Internal Service URLs ──────────────────────────────────────────
MCP_SERVER_URL=http://localhost:8001
MCP_API_KEY=your-mcp-api-key
AGENT_SERVICE_URL=http://localhost:8002
API_SERVICE_URL=http://localhost:8000

# ── Cloud Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
ENABLE_CLOUD_LOGGING=false

# ── Optional: Pub/Sub async mode ───────────────────────────────────
PUBSUB_TOPIC=orcheflow-workflows
ENABLE_ASYNC_MODE=false
